# Environment Variables Template
# Copy this file to .env.local for local development
# Add actual values to Netlify environment variables for production

# Application Environment
VITE_APP_ENV=production
VITE_APP_NAME=Feraj Solar Limited
VITE_APP_VERSION=1.3.0

# Supabase Configuration (Production)
VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# API Configuration
VITE_API_URL=https://api.ferajsolar.com/v1
VITE_API_TIMEOUT=10000

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true
VITE_ENABLE_DEBUG_MODE=false

# External Services
VITE_GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
VITE_STRIPE_PUBLIC_KEY=pk_live_...
# Hosted Stripe Checkout URL used by the cart checkout fallback
VITE_STRIPE_CHECKOUT_URL=url_to_stripe_checkout_session_endpoint
# Company Information
VITE_COMPANY_NAME=Feraj Solar Limited
VITE_COMPANY_EMAIL=info@ferajsolar.com
VITE_COMPANY_PHONE=+254-XXX-XXXXXX
VITE_COMPANY_ADDRESS=Nairobi, Kenya
VITE_GITHUB_REPO=https://github.com/onyangojerry/Feraj-Energy-Limited

# Social Media Links
VITE_FACEBOOK_URL=
VITE_TWITTER_URL=
VITE_LINKEDIN_URL=
VITE_INSTAGRAM_URL=

# Map Configuration (if using maps)
VITE_GOOGLE_MAPS_API_KEY=
VITE_MAP_CENTER_LAT=-1.2921
VITE_MAP_CENTER_LNG=36.8219

# Email Configuration (for contact forms)
VITE_CONTACT_FORM_ENDPOINT=
VITE_NEWSLETTER_ENDPOINT=

# CDN Configuration
VITE_CDN_BASE_URL=https://cdn.ferajsolar.com

# Performance Configuration
VITE_ENABLE_SW=true

# Supabase Configuration
VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_CACHE_VERSION=v1