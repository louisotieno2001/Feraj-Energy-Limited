# Environment Variables Template
# Copy this file to .env.local for local development
# Add actual values to Netlify environment variables for production

# Application Environment
VITE_APP_ENV=development
VITE_APP_NAME=Feraj Solar Limited
VITE_APP_VERSION=1.0.0

# API Configuration
VITE_API_URL=http://localhost:3000/api/v1
VITE_API_TIMEOUT=10000

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_REPORTING=false
VITE_ENABLE_DEBUG_MODE=true

# External Services
VITE_GOOGLE_ANALYTICS_ID=
VITE_SENTRY_DSN=
VITE_STRIPE_PUBLIC_KEY=

# Company Information
VITE_COMPANY_NAME=Feraj Solar Limited
VITE_COMPANY_EMAIL=info@ferajsolar.com
VITE_COMPANY_PHONE=+254-XXX-XXXXXX
VITE_COMPANY_ADDRESS=Nairobi, Kenya
VITE_GITHUB_REPO=https://github.com/onyangojerry/Feraj-Energy-Limited

# Social Media Links
VITE_FACEBOOK_URL=
VITE_TWITTER_URL=
VITE_LINKEDIN_URL=
VITE_INSTAGRAM_URL=

# Map Configuration (if using maps)
VITE_GOOGLE_MAPS_API_KEY=
VITE_MAP_CENTER_LAT=-1.2921
VITE_MAP_CENTER_LNG=36.8219

# Email Configuration (for contact forms)
VITE_CONTACT_FORM_ENDPOINT=
VITE_NEWSLETTER_ENDPOINT=

# CDN Configuration
VITE_CDN_BASE_URL=https://cdn.ferajsolar.com

# Performance Configuration
VITE_ENABLE_SW=true
VITE_CACHE_VERSION=v1